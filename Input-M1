local plrs = game:GetService("Players")
local uis = game:GetService("UserInputService")
local lp = plrs.LocalPlayer

local dist = 30

local function getEv()
	local char = lp.Character
	if not char then return nil end
	for _, v in ipairs(char:GetDescendants()) do
		if v:IsA("RemoteEvent") and v.Name == "Event" then
			return v
		end
	end
	return nil
end

local function aura()
	local rem = getEv()
	if not rem then return end
	
	local char = lp.Character
	local root = char and (char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso"))
	if not root then return end
	
	for _, p in ipairs(plrs:GetPlayers()) do
		if p ~= lp then
			local pchar = p.Character
			local hum = pchar and pchar:FindFirstChild("Humanoid")
			if hum and hum.Health > 0 then
				local proot = pchar:FindFirstChild("HumanoidRootPart") or pchar:FindFirstChild("Torso")
				if proot then
					local mag = (root.Position - proot.Position).Magnitude
					if mag <= dist then
						rem:FireServer(proot, "damage")
					end
				end
			end
		end
	end
end

uis.InputBegan:Connect(function(io, p)
	if p then return end
	if io.UserInputType == Enum.UserInputType.MouseButton1 or io.KeyCode == Enum.KeyCode.ButtonR2 then
		aura()
	end
end)
